#include <dt-bindings/zmk/mouse.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

&lt {
    tapping-term-ms = <200>;
    flavor = "balanced";
    quick-tap-ms = <150>;
};

/ {
    behaviors {
        tmv_coarse: trackball_coarse {
            compatible = "zmk,behavior-point-device-directional";
            #binding-cells = <0>;
            mode = "move-mode";
            scale-multiplier = <3>;  // Normal speed
        };
        
        tmv_fine: trackball_fine {
            compatible = "zmk,behavior-point-device-directional";
            #binding-cells = <0>;
            mode = "move-mode";
            scale-multiplier = <1>;  // Sniper mode (slower/more precise)
        };

        tsl: trackball_scroll {
            compatible = "zmk,behavior-point-device-directional";
            #binding-cells = <0>;
            mode = "scroll-mode";
            scale-multiplier = <1>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        layer_0 {
            bindings = <
&kp ESC        &kp N1  &kp N2  &kp N3            &kp N4     &kp N5      &kp N6     &kp N7         &kp N8         &kp N9   &kp N0            &kp BACKSPACE
&kp LS(TAB)    &kp Q   &kp W   &kp F             &kp P      &kp B       &kp J      &kp L          &kp U          &kp Y    &kp SINGLE_QUOTE  &kp DEL
&kp LC(LCAPS)  &kp A   &kp R   &kp S             &kp T      &kp G       &kp M      &kp N          &kp E          &kp I    &kp O             &kp TAB
&kp LCTRL      &kp Z   &kp X   &kp C             &kp D      &kp V       &kp K      &kp H          &kp LS(COMMA)  &kp DOT  &kp FSLH          &kp MINUS
                               &kp LEFT_COMMAND  &kp SPACE  &mo 1       &kp ENTER  &kp BACKSPACE
                                                 &mkp MB1   &mkp MB2    &mo 2
            >;

            trackball-bindings = <&tmv_coarse>;
        };

        layer_1 {
            bindings = <
&kp F1           &kp F2                &kp F3                 &kp F4          &kp F5           &kp F6            &kp F7             &kp F8            &kp F9      &kp F10            &kp F11     &kp F12
&kp EXCLAMATION  &kp AMPERSAND         &kp BACKSLASH          &kp SQT         &kp COLON        &kp UNDERSCORE    &kp LESS_THAN      &kp GREATER_THAN  &kp UP      &kp HASH           &kp DOLLAR  &bootloader
&kp PIPE         &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp LEFT_BRACE  &kp RIGHT_BRACE  &kp EQUAL         &kp F12            &kp LEFT          &kp DOWN    &kp RIGHT          &none       &none
&kp SEMICOLON    &kp LEFT_BRACKET      &kp RIGHT_BRACKET      &kp PERCENT     &kp ASTERISK     &kp MINUS         &none              &kp AT_SIGN       &kp PERIOD  &kp RIGHT_BRACKET  &none       &kp EQUAL
                                                              &kp LEFT_WIN    &kp SPACE        &none             &kp DOUBLE_QUOTES  &kp PERIOD
                                                                              &mkp MB1         &mkp MB2          &kp SLASH
            >;

            trackball-bindings = <&tsl>;
        };

        layer_2 {
            bindings = <
&trans  &trans  &trans        &trans        &trans        &trans     &trans        &trans  &trans  &trans  &trans  &trans
&trans  &trans  &kp NUMBER_7  &kp NUMBER_8  &kp NUMBER_9  &trans     &trans        &trans  &trans  &trans  &trans  &trans
&trans  &trans  &kp NUMBER_4  &kp NUMBER_5  &kp NUMBER_6  &kp TAB    &trans        &trans  &trans  &trans  &trans  &trans
&trans  &trans  &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &trans     &trans        &trans  &trans  &trans  &trans  &trans
                              &kp N0        &trans        &trans     &trans        &trans
                                            &trans        &trans     &kp LEFT_ALT
            >;

            trackball-bindings = <&tmv_fine>;
        };
    };
};
